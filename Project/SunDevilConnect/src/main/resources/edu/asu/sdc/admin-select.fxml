<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.asu.sdc.ui.AdminSelectController"
      alignment="CENTER"
      spacing="15"
      style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e3a8a);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Select Admin Profile"
           style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;" />

    <ComboBox fx:id="adminBox"
              prefWidth="260" />

    <Button text="Continue"
            onAction="#handleContinue"
            prefWidth="200"
            style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold;" />

    <Label fx:id="statusLabel"
           style="-fx-text-fill: #dbeafe;" />

    <Button text="Back"
            onAction="#handleBack"
            prefWidth="200"
            style="-fx-background-color: #475569; -fx-text-fill: white;" />

</VBox>