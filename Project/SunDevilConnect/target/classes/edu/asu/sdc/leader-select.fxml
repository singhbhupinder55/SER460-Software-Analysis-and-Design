<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.asu.sdc.ui.LeaderSelectController"
           style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e3a8a);">

    <VBox spacing="18"
          maxWidth="480"
          style="-fx-background-color: rgba(15, 23, 42, 0.92); -fx-background-radius: 18; -fx-border-radius: 18; -fx-border-color: #334155; -fx-border-width: 1;">

        <padding>
            <Insets top="28" right="30" bottom="28" left="30"/>
        </padding>

        <Label text="Select Club Leader"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" />

        <Label text="Choose a leader to manage the associated club dashboard."
               wrapText="true"
               style="-fx-text-fill: #dbeafe; -fx-font-size: 14px;" />

        <VBox spacing="8">
            <Label text="Leader"
                   style="-fx-text-fill: white; -fx-font-weight: bold;" />

            <ComboBox fx:id="leaderBox"
                      promptText="Select a club leader"
                      prefWidth="360" />
        </VBox>

        <HBox spacing="12">
            <Button text="Continue"
                    onAction="#handleContinue"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

            <Button text="Back"
                    onAction="#handleBack"
                    style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />
        </HBox>

        <Label fx:id="statusLabel"
               style="-fx-text-fill: #dbeafe; -fx-font-size: 13px;" />
    </VBox>
</StackPane>