<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.asu.sdc.ui.EventDetailsController"
           style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e3a8a);">

    <VBox spacing="16"
          maxWidth="700"
          style="-fx-background-color: rgba(15, 23, 42, 0.92); -fx-background-radius: 18; -fx-border-radius: 18; -fx-border-color: #334155; -fx-border-width: 1;">

        <padding>
            <Insets top="28" right="30" bottom="28" left="30"/>
        </padding>

        <Label text="Event Details"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" />

        <Label fx:id="titleLabel"
               wrapText="true"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;" />

        <Region prefHeight="4" />

        <Label fx:id="descriptionLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="dateTimeLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="locationLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="categoryLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="paidLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="popularityLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="capacityLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;" />

        <Label fx:id="statusLabel"
               wrapText="true"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #93c5fd;" />

        <Region prefHeight="8" />

        <Button text="Back"
                onAction="#handleBack"
                maxWidth="120"
                style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />
    </VBox>
</StackPane>